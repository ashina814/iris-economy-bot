DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me
# 任意: 開発中に特定ギルドだけへ即時スラッシュコマンド登録したい場合に設定。
DISCORD_GUILD_ID=
# 任意: 各種ログ送信先チャンネル（給与配布・招待成立など）。
DISCORD_LOG_CHANNEL_ID=
# 任意: 発言/通話ランク昇格通知の送信先。未設定なら DISCORD_LOG_CHANNEL_ID を使います。
DISCORD_RANK_CHANNEL_ID=
BOT_PREFIX=!eco
# 任意: 運営パネル・給与配布・審査・取引対応を実行できるDiscordユーザーID。カンマ区切り。
# 空なら開発用として ManageGuild 権限保持者が実行可。
ECONOMY_ADMIN_IDS=

# 内部Economy API。Discord Activityバックエンドなど、同一ホスト内の信頼済みサーバー専用です。
# 未設定の場合、内部APIは起動しません。ブラウザから直接呼ばせないでください。
IRIS_INTERNAL_API_KEY=
IRIS_INTERNAL_API_HOST=127.0.0.1
IRIS_INTERNAL_API_PORT=8787
IRIS_INTERNAL_API_MAX_BODY_BYTES=16384
# カジノ精算時の異常な高額配当を防ぐ上限。
IRIS_CASINO_MAX_PAYOUT_MULTIPLIER=100
IRIS_CASINO_MAX_PAYOUT_RIS=100000000

# 二人宿。公開宿は無料、シークレット宿は相手を選ぶ非公開VCです。
YADO_PUBLIC_COST=0
YADO_SECRET_COST=10000
YADO_EXTRA_SEAT_COST=5000
YADO_MAX_EXTRA_SEATS=8
YADO_DURATION_HOURS=12
